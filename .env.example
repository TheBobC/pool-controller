# Copy to .env and fill in values.  .env is gitignored.
# Every variable below is optional — config.py ships sensible defaults.

# --- MQTT (required for HA integration) ---
MQTT_HOST=10.0.0.16
MQTT_PORT=1883
MQTT_USER=changeme
MQTT_PASSWORD=changeme
MQTT_TOPIC_PREFIX=jarvis/pool/TudorPool
HA_DISCOVERY_PREFIX=homeassistant

# --- Pump (Hayward EcoStar via USB RS485) ---
PUMP_PORT=/dev/ttyUSB0
PUMP_BAUD=19200

# --- Salt cell / fans (GeeekPi 4-ch relay HAT) ---
CELL_I2C_ADDR=0x10
CELL_RELAY_CH_GATE=1
CELL_RELAY_CH_POLARITY=2
FAN_RELAY_CH=3
POLARITY_SWITCH_DELAY_S=3.0
FAN_TEMP_THRESHOLD=90.0

# --- ADS1115 ADC ---
ADS_I2C_ADDR=0x48
ADS_VCC=3.3

# --- Atlas EZO-EC conductivity probe ---
EC_PORT=/dev/serial0
EC_BAUD=9600

# --- Flow switch ---
FLOW_GPIO=17

# --- Persistence ---
STATE_FILE=state.json

# --- Optional integrations ---
HA_HOST=
HA_PORT=8123
HA_TOKEN=
ANTHROPIC_API_KEY=
